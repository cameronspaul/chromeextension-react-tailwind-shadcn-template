{
  "name": "chrome-extension-react-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A modern Chrome extension built with React, Vite, Tailwind CSS, and shadcn/ui",
  "scripts": {
    "dev": "node scripts/post-build.js --watch",
    "build": "tsc -b && vite build && node scripts/post-build.js",
    "build:dev": "tsc -b && vite build --mode development && node scripts/post-build.js",
    "icons": "node scripts/convert-icon.js"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "extpay": "^3.1.2",
    "framer-motion": "^12.24.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.9.4",
    "simple-icons": "^16.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.14",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.313",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "chokidar": "^4.0.3",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.7"
  },
  "keywords": [
    "chrome-extension",
    "react",
    "vite",
    "tailwindcss",
    "shadcn-ui",
    "manifest-v3",
    "typescript"
  ],
  "author": "",
  "license": "MIT"
}
